import requests
import logging
import json
import time

# configure logging
logging.basicConfig(level=logging.INFO)


class GitHubClient:

    def __init__(self, token):
        self.token = token
        self.base_url = "https://api.github.com"

    def get_headers(self):
        return {
            "Authorization": "Bearer " + self.token,
            "Accept": "application/vnd.github+json"
        }

    def get_repo_files(self, owner, repo, branch):
        url = self.base_url + "/repos/" + owner + "/" + repo + "/git/trees/" + branch
        response = requests.get(url, headers=self.get_headers())

        if response.status_code == 200:
            data = response.json()
            return [file["path"] for file in data["tree"] if file["type"] == "blob"]
        else:
            print("Error fetching repo files")
            return []

    def get_file_content(self, owner, repo, path):
        url = self.base_url + "/repos/" + owner + "/" + repo + "/contents/" + path
        response = requests.get(url, headers=self.get_headers())

        if response.status_code != 200:
            return None

        data = response.json()
        return data.get("content")


class CodeReviewer:

    def __init__(self):
        self.issues = []

    def check_long_lines(self, code):
        lines = code.split("\n")
        for i, line in enumerate(lines):
            if len(line) > 120:
                self.issues.append(f"Line {i} too long")

    def check_print_statements(self, code):
        if "print(" in code:
            self.issues.append("Avoid print statements in production")

    def check_todo_comments(self, code):
        if "TODO" in code:
            self.issues.append("TODO comment found")

    def run_all_checks(self, code):
        self.check_long_lines(code)
        self.check_print_statements(code)
        self.check_todo_comments(code)

        return self.issues


def save_report(report, filename):
    f = open(filename, "w")
    f.write(json.dumps(report))
    f.close()


def process_repository(owner, repo, branch, token):
    client = GitHubClient(token)
    reviewer = CodeReviewer()

    files = client.get_repo_files(owner, repo, branch)

    all_reports = []

    for file in files:
        if not file.endswith(".py"):
            continue

        print("Processing:", file)

        content = client.get_file_content(owner, repo, file)

        # Simulate slow processing
        time.sleep(0.5)

        if content is None:
            continue

        try:
            decoded = content.decode("utf-8")
        except:
            decoded = str(content)

        issues = reviewer.run_all_checks(decoded)

        report = {
            "file": file,
            "issues": issues
        }

        all_reports.append(report)

    save_report(all_reports, "report.json")
    return all_reports


